#!/usr/bin/env bash

set -euo pipefail

# ----- helpers ----------------------------------------------------------------

die() {
  echo "error: $*" >&2
  exit 1
}

# ----- arg parsing ------------------------------------------------------------

if [ $# -lt 1 ] || [ $# -gt 2 ]; then
  echo "usage: dev <branch-name> [base-branch]"
  exit 1
fi

branch="$1"
base="${2:-}"

# replace '/' with '-' for the worktree directory name
dir_name="${branch//\//-}"

# check we're inside a git repo
git rev-parse --git-dir >/dev/null 2>&1 || die "not inside a git repository"

# resolve the base branch to a usable ref (local branch or remote tracking)
base_ref=""
if [ -n "$base" ]; then
  if git show-ref --verify --quiet "refs/heads/$base"; then
    base_ref="$base"
  elif git show-ref --verify --quiet "refs/remotes/origin/$base"; then
    base_ref="origin/$base"
  else
    die "base branch '$base' not found"
  fi
fi

# ----- git worktree -----------------------------------------------------------

worktree_path="../worktrees/${dir_name}"

copy_env_and_pi() {
  local src="$1" dst="$2"
  # copy .env* files
  for f in "$src"/.env*; do
    [ -f "$f" ] && cp "$f" "$dst/"
  done
  # copy .pi/ folder
  [ -d "$src/.pi" ] && cp -r "$src/.pi" "$dst/"
}

if [ -d "$worktree_path" ]; then
  echo "→ worktree already exists at ${worktree_path}, moving in..."
elif git show-ref --verify --quiet "refs/heads/$branch"; then
  echo "→ creating worktree at ${worktree_path} for local branch '${branch}'..."
  git worktree add "$worktree_path" "$branch"
  copy_env_and_pi "$(pwd)" "$worktree_path"
elif git show-ref --verify --quiet "refs/remotes/origin/$branch"; then
  echo "→ creating worktree at ${worktree_path} for remote branch 'origin/${branch}'..."
  git worktree add "$worktree_path" -b "$branch" "origin/$branch"
  copy_env_and_pi "$(pwd)" "$worktree_path"
elif [ -n "$base_ref" ]; then
  echo "→ creating worktree at ${worktree_path} for new branch '${branch}' off '${base_ref}'..."
  git worktree add "$worktree_path" -b "$branch" "$base_ref"
  copy_env_and_pi "$(pwd)" "$worktree_path"
else
  echo "→ creating worktree at ${worktree_path} for new branch '${branch}'..."
  git worktree add "$worktree_path" -b "$branch"
  copy_env_and_pi "$(pwd)" "$worktree_path"
fi

echo "→ moving into worktree..."
cd "$worktree_path"

# ----- tmux session -----------------------------------------------------------

session="dev-${dir_name}"
worktree_abs="$(pwd)"

# Make sure the tmux server is rooted at a stable directory ($HOME). If the
# server is first spawned from inside a worktree, its working directory becomes
# invalid the moment that worktree is removed, and every *new* pane then inherits
# the dangling cwd and dies with:
#   shell-init: error retrieving current directory: getcwd: cannot access ...
# (the broken server cwd also makes tmux silently ignore `-c`). Spawning the
# server from $HOME up front makes it immune to worktree deletion. This is a
# no-op when a server is already running.
if ! tmux info >/dev/null 2>&1; then
  (cd "$HOME" && tmux start-server)
fi

if tmux has-session -t="$session" 2>/dev/null; then
  echo "→ tmux session '${session}' already exists, attaching..."
else
  echo "→ starting tmux session '${session}'..."

  # window 1: shell
  tmux new-session -d -s "$session" -n shell -c "$worktree_abs"

  # window 2: vim (run inside an interactive shell; stays open as shell after quitting)
  tmux new-window -t "$session" -n vim -c "$worktree_abs"
  tmux send-keys -t "${session}:vim" 'nvim' C-m

  # window 3: pi (run inside an interactive shell so nvm/PATH is loaded)
  tmux new-window -t "$session" -n pi -c "$worktree_abs"
  tmux send-keys -t "${session}:pi" 'pi' C-m

  # focus the shell window
  tmux select-window -t "${session}:0"
fi

if [ -n "${TMUX:-}" ]; then
  tmux switch-client -t "$session"
else
  tmux attach-session -t "$session"
fi
